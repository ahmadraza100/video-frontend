{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/staticwebapp*", "/assets/*", "/*.css", "/*.js", "/*.png", "/*.jpg", "/*.svg"]
  },
  "routes": [
    {
      "route": "/",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
